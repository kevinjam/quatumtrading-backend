# ─── Core (required) ───────────────────────────────────────────
MONGO_URL=mongodb+srv://USER:PASS@CLUSTER/dbname?retryWrites=true&w=majority
DB_NAME=quatumtrading_db

# Comma-separated SPA origins (no spaces required; * is ignored with credentials)
CORS_ORIGINS=https://your-frontend.vercel.app,http://localhost:3000

# SPA origin used after Google OAuth (no trailing slash)
FRONTEND_URL=https://your-frontend.vercel.app

# Google OAuth (Web client) — redirect URI must match Google Cloud Console
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://your-api.example.com/api/auth/google/callback

# Cookies for cross-origin SPA (Vercel ↔ API on different hosts)
COOKIE_SECURE=true
COOKIE_SAMESITE=none

# ─── Market / AI ────────────────────────────────────────────────
FINNHUB_KEY=
ALPHAVANTAGE_KEY=
EMERGENT_LLM_KEY=
SEC_USER_AGENT=QuantTradingAnalysis contact@yourdomain.com

# ─── Stripe ─────────────────────────────────────────────────────
STRIPE_API_KEY=
STRIPE_PRICE_PLUS=
STRIPE_PRICE_ULTRA=
STRIPE_WEBHOOK_SECRET=
PAYWALL_ENABLED=true

# ─── Runtime (optional; hosts usually inject PORT) ──────────────
# PORT=8000
